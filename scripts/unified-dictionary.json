#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
­¤öŹ NUR Lingo ŌĆō Unified Dictionary Generator
=============================================
Reads ALL sources:
  - database.ts (v, p, t functions)
  - dictionary.json
  - full-dictionary.json
  - Headers_dictionary.json
Merges and creates unified-dictionary.json with all entries.

USAGE:
    python scripts/generate_unified_dictionary.py
"""

import os
import re
import json
from pathlib import Path

PROJECT_ROOT = Path(__file__).parent.parent
DB_PATH = PROJECT_ROOT / "src" / "lib" / "content" / "database.ts"
OUTPUT_PATH = PROJECT_ROOT / "data" / "dictionaries" / "unified-dictionary.json"

# ­¤ōé į▒š╝š»šĪ JSON ųåšĪšĄš¼šźųĆš½ ųüšĪšČš»
JSON_SOURCES = [
    PROJECT_ROOT / "data" / "dictionaries" / "dictionary.json",
    PROJECT_ROOT / "data" / "dictionaries" / "full-dictionary.json",
    PROJECT_ROOT / "data" / "dictionaries" / "Headers_dictionary.json",
]

def extract_from_database(db_path):
    """Extract v(), p(), t() from database.ts"""
    if not db_path.exists():
        return []
    with open(db_path, "r", encoding="utf-8") as f:
        content = f.read()

    entries = []

    # v() calls: v("id", "hy", "en", "ru")
    v_pattern = re.compile(
        r'v\s*\(\s*["\']([^"\']+)["\']\s*,\s*["\']([^"\']*?)["\']\s*,\s*["\']([^"\']*?)["\']\s*,\s*["\']([^"\']*?)["\']\s*\)',
        re.DOTALL
    )
    for match in v_pattern.finditer(content):
        id_val, hy, en, ru = match.groups()
        if hy.strip() or en.strip() or ru.strip():
            entries.append({
                "hy": hy.strip(),
                "en": en.strip(),
                "ru": ru.strip(),
                "type": "vocab",
                "original_id": id_val
            })

    # p() calls: p("id", "hy", "en", "ru")
    p_pattern = re.compile(
        r'p\s*\(\s*["\']([^"\']+)["\']\s*,\s*["\']([^"\']*?)["\']\s*,\s*["\']([^"\']*?)["\']\s*,\s*["\']([^"\']*?)["\']',
        re.DOTALL
    )
    for match in p_pattern.finditer(content):
        id_val, hy, en, ru = match.groups()
        if hy.strip() or en.strip() or ru.strip():
            entries.append({
                "hy": hy.strip(),
                "en": en.strip(),
                "ru": ru.strip(),
                "type": "phrase",
                "original_id": id_val
            })

    # t() calls: t("speaker", "hy", "en", "ru")
    t_pattern = re.compile(
        r't\s*\(\s*["\'](nurik|user)["\']\s*,\s*["\']([^"\']*?)["\']\s*,\s*["\']([^"\']*?)["\']\s*,\s*["\']([^"\']*?)["\']\s*\)',
        re.DOTALL
    )
    for match in t_pattern.finditer(content):
        speaker, hy, en, ru = match.groups()
        if hy.strip() or en.strip() or ru.strip():
            entries.append({
                "hy": hy.strip(),
                "en": en.strip(),
                "ru": ru.strip(),
                "type": "dialogue",
                "original_id": f"{speaker}_{len(entries)}"
            })

    return entries

def extract_from_json(json_path):
    """Extract entries from any JSON dictionary (list or dict format)"""
    if not json_path.exists():
        return []
    try:
        with open(json_path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except:
        return []

    entries = []
    if isinstance(data, list):
        for entry in data:
            if "hy" in entry and "en" in entry and "ru" in entry:
                entries.append({
                    "hy": entry["hy"],
                    "en": entry["en"],
                    "ru": entry["ru"],
                    "type": entry.get("type", "vocab"),
                    "original_id": entry.get("id", entry.get("en", ""))
                })
    elif isinstance(data, dict):
        for key, entry in data.items():
            if isinstance(entry, dict) and "hy" in entry and "en" in entry and "ru" in entry:
                entries.append({
                    "hy": entry["hy"],
                    "en": entry["en"],
                    "ru": entry["ru"],
                    "type": entry.get("type", "vocab"),
                    "original_id": key
                })
    return entries

def merge_entries(all_entries):
    """Merge and deduplicate by (hy, en, ru)"""
    seen = set()
    merged = []
    for entry in all_entries:
        key = (entry["hy"], entry["en"], entry["ru"])
        if key not in seen:
            seen.add(key)
            merged.append(entry)
    return merged

def main():
    print("­¤öŹ Generating unified dictionary from ALL sources...")

    # 1. Extract from database.ts
    db_entries = extract_from_database(DB_PATH)
    print(f"­¤ōÜ From database.ts: {len(db_entries)} entries")

    # 2. Extract from JSON files
    json_entries = []
    for src in JSON_SOURCES:
        entries = extract_from_json(src)
        print(f"­¤ōÜ From {src.name}: {len(entries)} entries")
        json_entries.extend(entries)

    # 3. Merge and deduplicate
    all_entries = merge_entries(db_entries + json_entries)
    print(f"­¤ōŖ Merged: {len(all_entries)} unique entries")

    # 4. Assign numeric IDs
    unified_dict = []
    for idx, entry in enumerate(all_entries, 1):
        new_id = f"{idx:06d}"
        unified_dict.append({
            "id": new_id,
            "hy": entry["hy"],
            "en": entry["en"],
            "ru": entry["ru"],
            "type": entry["type"],
            "original_id": entry.get("original_id", ""),
            "audio": {
                "hy": f"/audio/hy/{new_id}.mp3",
                "en": f"/audio/en/{new_id}.mp3",
                "ru": f"/audio/ru/{new_id}.mp3"
            }
        })

    # 5. Write output
    OUTPUT_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(OUTPUT_PATH, "w", encoding="utf-8") as f:
        json.dump(unified_dict, f, indent=2, ensure_ascii=False)

    print(f"\nŌ£ģ Unified dictionary saved to: {OUTPUT_PATH}")
    print(f"   Total entries: {len(unified_dict)}")
    print(f"   First entry: {unified_dict[0] if unified_dict else 'None'}")

    # Breakdown by type
    types = {}
    for entry in unified_dict:
        t = entry["type"]
        types[t] = types.get(t, 0) + 1
    print("   Breakdown:")
    for t, count in types.items():
        print(f"      {t}: {count}")

if __name__ == "__main__":
    main()